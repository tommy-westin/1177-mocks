<xs:schema xmlns:xs='http://www.w3.org/2001/XMLSchema' 
    xmlns:tns='urn:riv:strategicresourcemanagement:persons:person:UnlinkPersonIdentityResponder:4'                
    xmlns:strategicresourcemanagementpersonsperson='urn:riv:strategicresourcemanagement:persons:person:5'
    targetNamespace='urn:riv:strategicresourcemanagement:persons:person:UnlinkPersonIdentityResponder:4'
    elementFormDefault='qualified'
    attributeFormDefault='unqualified'
    version='4.0'>

    <xs:import schemaLocation='../../core_components/strategicresourcemanagement_persons_person_5.0.xsd' namespace='urn:riv:strategicresourcemanagement:persons:person:5' />


    <xs:element name='UnlinkPersonIdentity' type='tns:UnlinkPersonIdentityType'/>

    <xs:complexType name='UnlinkPersonIdentityType'>
        <xs:annotation>
            <xs:documentation>
                Tjänst för att koppla isär en tidigare koppling mellan 2 identiteter. T.ex  en koppling mellan en reservidentitet (LRID/NRID) och ett personnummer (PNR). Skälet till isärkopplingen är normalt en felaktig tidigare genomförd koppling.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="actor" type="strategicresourcemanagementpersonsperson:ActorType"/>
            <xs:element name="unlinkFromIdentity" type="strategicresourcemanagementpersonsperson:IIType"/>
            <xs:element name="unlinkIdentity" type="strategicresourcemanagementpersonsperson:IIType"/>
            <xs:any maxOccurs="unbounded" minOccurs="0" namespace="##other" processContents="lax"/>
        </xs:sequence>
    </xs:complexType>

    <xs:element name='UnlinkPersonIdentityResponse' type='tns:UnlinkPersonIdentityResponseType'/>

    <xs:complexType name='UnlinkPersonIdentityResponseType'>
        <xs:annotation>
            <xs:documentation>
                Tjänst för att koppla isär en tidigare koppling mellan 2 identiteter. T.ex  en koppling mellan en reservidentitet (LRID/NRID) och ett personnummer (PNR). Skälet till isärkopplingen är normalt en felaktig tidigare genomförd koppling.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="result" type="strategicresourcemanagementpersonsperson:ResultType"/>
            <xs:any maxOccurs="unbounded" minOccurs="0" namespace="##other" processContents="lax"/>
        </xs:sequence>
    </xs:complexType>
</xs:schema>
