                <soap:header use='literal' message='tns:SearchPersonsForProfileByOrderRequest' part='LogicalAddress' />
                <soap:body use='literal' parts='parameters' />
            </wsdl:input>
            <wsdl:output>
                <soap:body use='literal' />
            </wsdl:output>
        </wsdl:operation>
    </wsdl:binding>

    <wsdl:service name='SearchPersonsForProfileByOrderResponderService'>
