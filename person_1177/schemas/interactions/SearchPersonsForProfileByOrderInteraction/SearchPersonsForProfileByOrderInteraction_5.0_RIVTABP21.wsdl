<wsdl:definitions name='SearchPersonsForProfileByOrderInteraction'
    xmlns:wsdl='http://schemas.xmlsoap.org/wsdl/'
    xmlns:soap='http://schemas.xmlsoap.org/wsdl/soap/'
    xmlns:xs='http://www.w3.org/2001/XMLSchema'
    xmlns:tjsr='urn:riv:strategicresourcemanagement:persons:person:SearchPersonsForProfileByOrderResponder:5'
    xmlns:itr='urn:riv:itintegration:registry:1'
    xmlns:tns='urn:riv:strategicresourcemanagement:persons:person:SearchPersonsForProfileByOrder:5:rivtabp21'
