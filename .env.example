# Kopiera till .env och fyll i värden

# Extern URL som exponeras via Cloudflare Tunnel (utan trailing slash)
MOCK_HOST=https://1177-mock.din-domain.com

# Token från: Cloudflare Zero Trust → Networks → Tunnels → skapa tunnel → kopiera token
CF_TUNNEL_TOKEN=eyJ...

# API-nyckel för /admin/* och POST /scenario/* (lämna tom för att stänga av skyddet)
ADMIN_API_KEY=byt-ut-mig
